PYGEOAPI_CONFIG=data/pygeoapi/pygeoapi-config.yml
PYGEOAPI_OPENAPI=data/pygeoapi/pygeoapi-openapi.yml

# ERA5-Land downloads use DestinE Earth Data Hub (https://earthdatahub.destine.eu).
# Authentication is handled via ~/.netrc — no API key is required here.
# See docs/setup_guide.md for setup instructions.

# Download cache directory for climate data
# DOWNLOAD_DIR=./target/data

# Default country code for datasets that require one (for example WorldPop)
# COUNTRY_CODE=SLE

# Public Climate API base URL — set this when running behind a reverse proxy
# so that STAC asset hrefs and links use the public address instead of the
# internal request URL.
# CLIMATE_API_BASE_URL=http://localhost:8000

# Allowed origins for Zarr browser access (comma-separated)
# CLIMATE_API_ZARR_BROWSER_ORIGINS=http://localhost:3000
